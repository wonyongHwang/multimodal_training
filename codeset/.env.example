#결과 저장용 db
DB_HOST=dpip
DB_PORT=dbport
DB_NAME=dbname
DB_USER=userid
DB_PASSWORD=userpw

# ===== Hugging Face 설정 =====
HF_TOKEN=yourHF
HF_DATASET_REPO=yourHFID/your_dataset_name

# ===== 데이터셋 경로 설정 =====
#OCR_ROOT=./dataset/05. 멀티모달 OCR/OCR손글씨
OCR_ROOT=./dataset/05. 멀티모달 OCR/OCR손글씨
TEXT_JSON_PATH=./dataset/04. 멀티모달 샘플/text_samples/sample_data.json

# ===== OCR 처리 설정 =====
MAX_OCR_SAMPLES=
CHUNK_SIZE=500
DATASET_DIR=./dataset/ocr_dataset
SEED=42

# ===== OCR 프롬프트 설정 =====
OCR_INSTR_TEXT=이미지에서 손글씨로 작성된 텍스트를 모두 인식하여 전사하세요.
OCR_INPUT_TEXT=이미지에 포함된 모든 텍스트를 공백으로 구분하여 순서대로 나열해주세요.

# ===== 스포츠 데이터 준비 설정 (★01. 데이터 준비_멀티모달데이터_Gemma3_스포츠) =====
IMAGE_ROOT=./dataset/04. 멀티모달 샘플/image_samples
IMAGE_META_ROOT=./dataset/04. 멀티모달 샘플/image_samples/labels.csv
MAX_IMAGE_SAMPLES_PER_CLASS=
IMAGE_INSTRUCTION=이미지를 보고 필라테스 동작명을 분류하고 한 줄 설명을 제공하세요.
IMAGE_INPUT=동작명과 간단한 설명을 한국어로 답하세요.

# ===== 파인튜닝 설정 (02. 파인튜닝_멀티모달데이터_Gemma3) =====
# .env 값을 변경해 시뮬레이션 가능 — 코드 수정 없이 튜닝 인자 조절
DATASET_REPO=hyokwan/multi_modal_sample
BASE_MODEL=google/gemma-3-4b-it
OUTPUT_BASE_DIR=./models

# 데이터 샘플 수 제한 (비워두면 전체 사용)
MAX_TRAIN_SAMPLES=
MAX_EVAL_SAMPLES=

# 학습 하이퍼파라미터
MAX_SEQ_LENGTH=768
PER_DEVICE_TRAIN_BATCH_SIZE=1
PER_DEVICE_EVAL_BATCH_SIZE=1
GRAD_ACCUM=4
NUM_EPOCHS=5
LEARNING_RATE=2e-4
LOGGING_STEPS=10
SAVE_STEPS=100

# LoRA 하이퍼파라미터
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05

# ===== 모델 병합 및 업로드 설정 (★03_데이터병합 및 저장_멀티모달데이터_Gemma3) =====
# 파인튜닝으로 생성된 LoRA 어댑터 경로 (OUTPUT_BASE_DIR 아래 실제 폴더명 입력)
ADAPTER_PATH=./models/gemma3_multimodal_lora_output
# 병합 모델 로컬 저장 경로
MERGED_LOCAL_DIR=./models/gemma3_multimodal_merged
# HuggingFace Hub 업로드 레포 (yourHFID/repo_name 형식)
MERGED_MODEL_REPO=YOUR_HF_ID/multi_modal_model_g3
# 추론 테스트용 이미지 경로
TEST_IMAGE_PATH=./dataset/pilates_samples/bridge/bridge_001.png
